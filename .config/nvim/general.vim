" =====================
" General configuration
" =====================

" Syntax highlighting
syntax on
" Position in code
set number
" Highlight search results
set hlsearch
set incsearch
" Mouse support
set mouse=a
" Support 256 colors
set t_Co=256
" Split directions
set sb
set spr

" WhichKey config
let g:which_key_map.o = { 'name': '+open' }
let g:which_key_map.j = { 'name': '+jump' }
